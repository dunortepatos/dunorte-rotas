{
  "manifest_version": 3,
  "name": "Dunorte Maps Link Helper",
  "version": "1.0.0",
  "description": "Busca automaticamente o link curto de partilha do Google Maps para o sistema Dunorte.",
  "permissions": [
    "tabs",
    "scripting",
    "clipboardRead",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://maps.google.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Dunorte Maps Link Helper"
  }
}